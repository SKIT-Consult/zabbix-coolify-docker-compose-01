# Zabbix Coolify — Environment Variables
# Copy these into Coolify Environment section when deploying.
# CHANGE ALL PASSWORDS before deploying.

MYSQL_DATABASE=zabbix
MYSQL_USER=zabbix
MYSQL_PASSWORD=CHANGE_ME_zabbix_password
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_password

# Timezone for PHP (Zabbix web frontend)
PHP_TZ=Europe/Berlin

# Zabbix Server tuning (defaults are fine for small setups)
ZBX_CACHESIZE=32M
ZBX_STARTDBSYNCERS=2
